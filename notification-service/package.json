{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "Notification service for UPS LMS - handles email, SMS, and push notifications",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "debug": "node --inspect src/server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "db:migrate": "node scripts/migrate.js",
    "docker:build": "docker build -t ups-lms/notification:latest .",
    "docker:push": "docker push ups-lms/notification:latest",
    "health": "curl -f http://localhost:3003/health || exit 1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "pino": "^8.15.6",
    "pino-http": "^8.3.3",
    "pino-pretty": "^13.1.3",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-async-handler": "^1.2.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "http-status-codes": "^2.2.0",
    "uuid": "^9.0.0",
    "joi": "^17.9.2",
    "pg": "^8.11.3",
    "knex": "^2.5.1",
    "nodemailer": "^6.9.7",
    "twilio": "^3.10.0",
    "axios": "^1.5.0",
    "bull": "^4.11.4",
    "redis": "^4.6.7",
    "@godaddy/terminus": "^4.12.1",
    "prom-client": "^15.0.0",
    "express-prom-bundle": "^8.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.9",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
