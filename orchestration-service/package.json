{
  "name": "orchestration-service",
  "version": "1.0.0",
  "description": "Main orchestration service for UPS LMS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "debug": "node --inspect src/server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:e2e": "jest tests/e2e --forceExit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "docker:build": "docker build -t ups-lms/orchestration:latest .",
    "docker:push": "docker push ups-lms/orchestration:latest",
    "docker:run": "docker run -p 3002:3002 ups-lms/orchestration:latest",
    "health": "curl -f http://localhost:3002/health || exit 1",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "amqplib": "^0.10.3",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.0.0",
    "http-status-codes": "^2.2.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "knex": "^2.5.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "pino": "^8.15.6",
    "pino-http": "^8.3.3",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "redis": "^4.6.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.9",
    "eslint": "^8.48.0",
    "faker": "^5.5.3",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "testcontainers": "^9.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ]
  }
}
